# Copy this file to .env and adjust values for your environment.

# Container / ports
CLASH_CONTAINER_NAME=clash-sub-parser
CLASH_PORT=127.0.0.1:18080
CLASH_COMPAT_PORT=127.0.0.1:20000

# Database
# SQLite inside Docker volume, recommended default:
CLASH_DATABASE_URL=sqlite+aiosqlite:////data/clash_sub_parser.db
# PostgreSQL example:
# CLASH_DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/clash_sub_parser

# Subscription fetch behavior
CLASH_REQUEST_TIMEOUT_SECONDS=30
CLASH_REQUEST_MAX_BYTES=5242880
CLASH_REQUEST_USER_AGENT=ClashforWindows/0.20
CLASH_REQUEST_TRUST_ENV=false
CLASH_ALLOW_PRIVATE_FETCH_URLS=false
CLASH_DEFAULT_PROXY_TEST_URL=http://www.gstatic.com/generate_204
CLASH_SCHEDULER_ENABLED=true

# Optional token protection for the web UI/API/export endpoints.
# When enabled, open the UI normally and enter the token in the login form.
# Export/subscription URLs must carry token=<your-token> in the URL query because
# Clash clients usually cannot send custom headers.
CLASH_AUTH_ENABLED=false
CLASH_AUTH_TOKEN=
CLASH_AUTH_COOKIE_SECURE=false

# CORS (empty = same-origin only; set to your domain for cross-origin access)
# CLASH_CORS_ALLOW_ORIGINS=

# Optional proxy for upstream subscription fetching.
# These intentionally use CLASH_* names so your shell's HTTP_PROXY is not
# accidentally baked into the compose config.
CLASH_HTTP_PROXY=
CLASH_HTTPS_PROXY=
CLASH_ALL_PROXY=
CLASH_NO_PROXY=localhost,127.0.0.1
